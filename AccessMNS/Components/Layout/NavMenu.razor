    <div class="nav-item navlink-position" style="bottom: 0rem;">
        <MudTooltip Arrow="true" Placement="Placement.Right" Text="Déconnexion" Class="navbar-tooltip" Style="height: 30px; font-size: 16px; font-family: 'Lucida Sans Unicode'">
            <NavLink class="nav-link" href="weather" >
                <MudIcon Icon="@Icons.Material.Filled.Logout" Title="Déconnexion" Style="font-size: 32px"></MudIcon>
            </NavLink>
        </MudTooltip>
